<%#
  Override of decidim-core's `decidim/application/_document` partial (0.31.3).

  Upstream renders `link_to document.url, ...` unconditionally. When an
  attachment has neither an attached ActiveStorage file nor a link, its
  `url` is nil (e.g. a CarrierWave-era file that never migrated to
  ActiveStorage, or a blob deleted from storage). `link_to nil` then makes
  Rails fall back to `url_for(nil)`, which inside a cell raises
  `ActionController::UrlGenerationError` and 500s the whole page that lists
  the document (participatory space landing, meeting show, etc.).

  Guarding on `document.url.present?` lets a file-less attachment still show
  its title/metadata without a broken download link, instead of taking the
  page down.
%>
<div id="<%= dom_id(document) %>">
  <div class="card__list-content">
    <span class="card__list-title">
      <%= h attachment_title(document) %>
    </span>
    <% if document.description.present? %>
      <div class="card__list-text"><%= decidim_escape_translated(document.description) %></div>
    <% end %>
    <div class="card__list-metadata">
      <div><%= icon "file-text-line" %><%= document.file_type %></div>
      <% if document.file? %>
        <div><%= icon "scales-2-line" %><%= number_to_human_size(document.file_size) %></div>
      <% end %>
    </div>
  </div>
  <% if document.url.present? %>
    <% if document.file? %>
      <%= link_to document.url,
                  target: "_blank",
                  rel: "noopener noreferrer",
                  class: "button button__sm button__transparent-secondary flex-none",
                  title: t("decidim.application.document.download"),
                  data: { "external-link": false } do %>
        <%= t("decidim.application.document.download") %>
        <%= icon "download-line" %>
      <% end %>
    <% else %>
      <%= link_to document.url,
                  target: "_blank",
                  rel: "noopener noreferrer",
                  class: "button button__sm button__transparent-secondary flex-none",
                  title: t("decidim.application.document.visit_link"),
                  data: { "external-link": true } do %>
        <%= t("decidim.application.document.visit_link") %>
      <% end %>
    <% end %>
  <% end %>
</div>
